# MySQL (Prisma — presence data)
DATABASE_URL="mysql://user:password@localhost:3306/presence_db"

# JWT secret — any long random string
JWT_SECRET=change-me-to-a-long-random-string

# ERP SQL Server
MSSQL_SERVER=192.168.x.x\INSTANCE
MSSQL_DATABASE=PYLON
MSSQL_USER=sa
MSSQL_PASSWORD=your-mssql-password
MSSQL_PORT=1433
MSSQL_ENCRYPT=true

# SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.gr
SMTP_PASS=your-smtp-password
SMTP_FROM=your-email@domain.gr
TO_EMAIL=your-email@domain.gr

# Shared secret with ari-hub — must match SSO_SECRET in the hub's .env exactly
SSO_SECRET=change-me-to-match-ari-hub-sso-secret
